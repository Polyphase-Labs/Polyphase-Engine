#---------------------------------------------------------------------------------
# Clear the implicit built in rules
#---------------------------------------------------------------------------------
.SUFFIXES:
.SECONDARY:
#---------------------------------------------------------------------------------
export AS	:=	$(PREFIX)as
export CC	:=	$(PREFIX)gcc
export CXX	:=	$(PREFIX)g++
export AR	:=	$(PREFIX)gcc-ar
export OBJCOPY	:=	$(PREFIX)objcopy
export STRIP	:=	$(PREFIX)strip
export NM	:=	$(PREFIX)gcc-nm
export RANLIB	:=	$(PREFIX)gcc-ranlib

ifeq ($(V),1)
    SILENTMSG := @true
    SILENTCMD :=
else
    SILENTMSG := @echo
    SILENTCMD := @
endif

#---------------------------------------------------------------------------------
%.a:
#---------------------------------------------------------------------------------
	$(SILENTMSG) $(notdir $@)
	$(SILENTCMD)rm -f $@
	$(SILENTCMD)$(AR) -rc $@ $^

#---------------------------------------------------------------------------------
# W1: SHARED library rule — produces libPolyphaseGame.so. Linked from the same
# .o set as the game .a, but those objects must be PIC. To avoid clobbering the
# non-PIC objects under Intermediate/Linux/EngineGame, the `shared` target
# routes through a separate intermediate directory (see SHARED_BUILD below).
# soname matches the file name so the editor exe resolves via DT_NEEDED; the
# DT_RPATH points at $ORIGIN so the SO is loaded from next to the exe.
#---------------------------------------------------------------------------------
%.so:
	$(SILENTMSG) $(notdir $@)
	$(SILENTCMD)rm -f $@
	$(SILENTCMD)$(CXX) -shared -Wl,-soname,$(notdir $@) -Wl,-rpath,'$$ORIGIN' -o $@ $^ $(LIBPATHS) $(LIBS)

#---------------------------------------------------------------------------------
%.o: %.cpp
	$(SILENTMSG) $(notdir $<)
	$(SILENTCMD)$(CXX) -MMD -MP -MF $(DEPSDIR)/$*.d $(CXXFLAGS) -c $< -o $@ $(ERROR_FILTER)

#---------------------------------------------------------------------------------
%.o: %.c
	$(SILENTMSG) $(notdir $<)
	$(SILENTCMD)$(CC) -MMD -MP -MF $(DEPSDIR)/$*.d $(CFLAGS) -c $< -o $@ $(ERROR_FILTER)


#---------------------------------------------------------------------------------
# TARGET is the name of the output
# BUILD is the directory where object files & intermediate files will be placed
# SOURCES is a list of directories containing source code
# INCLUDES is a list of directories containing extra header files
#---------------------------------------------------------------------------------
TARGET		:=	$(notdir $(CURDIR))
SOURCES		:=	Source \
				Source/Engine \
				Source/Engine/Utils \
				Source/Engine/Animation \
				Source/Engine/Nodes \
				Source/Engine/Nodes/3D \
				Source/Engine/Nodes/Widgets \
				Source/Engine/Assets \
				Source/Engine/NodeGraph \
				Source/Engine/NodeGraph/Nodes \
				Source/Engine/NodeGraph/Domains \
				Source/Engine/UI \
				Source/Engine/Timeline \
				Source/Engine/Timeline/Tracks \
				Source/Plugins \
				Source/System Source/System/Linux \
				Source/Graphics \
				Source/Graphics/Vulkan \
				Source/Graphics/Vulkan/PostProcess \
				Source/Input \
				Source/Input/Linux \
				Source/Audio \
				Source/Audio/Linux \
				Source/Network \
				Source/Network/Linux \
				Source/Network/Http \
				Source/Network/Http/Backends \
				Source/Serial \
				Source/Serial/Linux \
				Source/LuaBindings \
				../External/Lua \
				../External/Vorbis \
				../External/IrrXML \
				../External/recastnavigation/Recast/Source/ \
				../External/recastnavigation/Detour/Source/
INCLUDES	:=	Source Source/Engine ../External ../External/Vorbis ../External/Bullet ../External/Lua ../External/Assimp/contrib/rapidjson $(VULKAN_SDK)/include ../External/recastnavigation/Recast/Include ../External/recastnavigation/Detour/Include External/PolyVox/include
OUTPUT_DIR	:=	$(CURDIR)/Build/Linux
BULLET_DIR	:=	$(CURDIR)/../External/Bullet
ASSIMP_DIR	:=	$(CURDIR)/../External/Assimp

#---------------------------------------------------------------------------------
# options for code generation
#---------------------------------------------------------------------------------

CFLAGS	= -g -O2 -Wall $(MACHDEP) -DPLATFORM_LINUX=1 -DAPI_VULKAN=1 $(INCLUDE)

ifneq ($(strip $(POLYPHASE_SHARED)),)
# W1: SHARED game-runtime engine — game-only sources, PIC objects, .so output.
# Also exports POLYPHASE_PIC=1 to recursive External sub-makes (e.g. Bullet)
# so their static archives are built with -fPIC into a separate intermediate
# directory, leaving the non-PIC static build untouched.
# POLYPHASE_DLL_BUILD=1 gates Engine.cpp's main/GameMain block out of the .so.
CFLAGS	+=	-DEDITOR=0 -fPIC -DPOLYPHASE_ENGINE_EXPORT=1 -DPOLYPHASE_DLL_BUILD=1
BUILD		:=	Intermediate/Linux/EngineGameShared
TARGET		:= PolyphaseGame
SHARED_BUILD := 1
export POLYPHASE_PIC := 1
else ifneq ($(strip $(POLYPHASE_EDITOR_SHARED)),)
# W1: SHARED editor engine — editor sources included, PIC objects, .so output.
# Same source set as the static editor below, with DLL_BUILD gating Engine.cpp's
# main/GameMain block and the OctHookAutoRegister auto-wire (the exe registers
# its hooks via RegisterOctHooks() at startup).
CFLAGS	+=	-DEDITOR=1 -DPOLYPHASE_IMGUI_EXPORT -fPIC -DPOLYPHASE_ENGINE_EXPORT=1 -DPOLYPHASE_DLL_BUILD=1
INCLUDES += ../External/Assimp ../External/IrrXML ../External/Zlib Source/Editor Source/Editor/ImGuizmo ../External/Imgui ../External/imgui-node-editor ../External/zep/include ../External/Crow ../External/asio External/libgit2/include
SOURCES +=	Source/Editor Source/Editor/ImGuizmo Source/Editor/Widgets Source/Editor/Hotkeys Source/Editor/Preferences Source/Editor/Preferences/General Source/Editor/Preferences/Appearance Source/Editor/Preferences/Appearance/Theme Source/Editor/Preferences/Appearance/Viewport Source/Editor/Preferences/Appearance/Viewport/TilemapGrid Source/Editor/Preferences/External Source/Editor/Preferences/Packaging Source/Editor/Preferences/Network Source/Editor/Preferences/Updates Source/Editor/Preferences/Input Source/Editor/Preferences/EditorHotkeys Source/Editor/ControllerServer Source/Editor/AutoUpdater Source/Editor/Addons Source/Editor/Packaging Source/Editor/AppSettings Source/Editor/ProjectSelect Source/Editor/Timeline Source/Editor/DebugLog Source/Editor/CliTerminal Source/Editor/NodeGraph Source/Editor/GamePreview Source/Editor/AnimationBrowser Source/Editor/Profiling Source/Editor/InputTester Source/Editor/ScriptCreator Source/Editor/ScriptEditor Source/Editor/SecondScreenPreview Source/Editor/ThemeEditor Source/Editor/SpriteAnimationEditor Source/Editor/TextureAtlas Source/Editor/TextureCrop Source/Editor/VoxelSculpt Source/Editor/TerrainSculpt Source/Editor/TilePaint Source/Editor/Validation Source/Editor/Runtime Source/Editor/Git Source/Editor/Git/Dialogs Source/Editor/Preferences/Git Source/Editor/LuaDebugger ../External/Imgui ../External/Imgui/misc/cpp ../External/imgui-node-editor
TARGET		:= PolyphaseEditor
BUILD		:=	Intermediate/Linux/EngineEditorShared
SHARED_BUILD := 1
export POLYPHASE_PIC := 1
else ifeq ($(strip $(POLYPHASE_EDITOR)),)
CFLAGS	+=	-DEDITOR=0
BUILD		:=	Intermediate/Linux/EngineGame
TARGET		:= EngineGame
else
CFLAGS	+=	-DEDITOR=1 -DPOLYPHASE_IMGUI_EXPORT
INCLUDES += ../External/Assimp ../External/IrrXML ../External/Zlib Source/Editor Source/Editor/ImGuizmo ../External/Imgui ../External/imgui-node-editor ../External/zep/include ../External/Crow ../External/asio External/libgit2/include
SOURCES +=	Source/Editor Source/Editor/ImGuizmo Source/Editor/Widgets Source/Editor/Hotkeys Source/Editor/Preferences Source/Editor/Preferences/General Source/Editor/Preferences/Appearance Source/Editor/Preferences/Appearance/Theme Source/Editor/Preferences/Appearance/Viewport Source/Editor/Preferences/Appearance/Viewport/TilemapGrid Source/Editor/Preferences/External Source/Editor/Preferences/Packaging Source/Editor/Preferences/Network Source/Editor/Preferences/Updates Source/Editor/Preferences/Input Source/Editor/Preferences/EditorHotkeys Source/Editor/ControllerServer Source/Editor/AutoUpdater Source/Editor/Addons Source/Editor/Packaging Source/Editor/AppSettings Source/Editor/ProjectSelect Source/Editor/Timeline Source/Editor/DebugLog Source/Editor/CliTerminal Source/Editor/NodeGraph Source/Editor/GamePreview Source/Editor/AnimationBrowser Source/Editor/Profiling Source/Editor/InputTester Source/Editor/ScriptCreator Source/Editor/ScriptEditor Source/Editor/SecondScreenPreview Source/Editor/ThemeEditor Source/Editor/SpriteAnimationEditor Source/Editor/TextureAtlas Source/Editor/TextureCrop Source/Editor/VoxelSculpt Source/Editor/TerrainSculpt Source/Editor/TilePaint Source/Editor/Validation Source/Editor/Runtime Source/Editor/Git Source/Editor/Git/Dialogs Source/Editor/Preferences/Git Source/Editor/LuaDebugger ../External/Imgui ../External/Imgui/misc/cpp ../External/imgui-node-editor
TARGET		:= EngineEditor
BUILD		:=	Intermediate/Linux/EngineEditor
endif

CXXFLAGS	=	$(CFLAGS)

LDFLAGS	=	-g $(MACHDEP) -Wl,-Map,$(notdir $@).map

#---------------------------------------------------------------------------------
# any extra libraries we wish to link with the project
#---------------------------------------------------------------------------------
LIBS	:=	-lvulkan -lxcb -lasound -lpthread -lm -ldl -lutil

#---------------------------------------------------------------------------------
# list of directories containing libraries, this must be the top level containing
# include and lib
#---------------------------------------------------------------------------------
LIBDIRS	:= $(VULKAN_SDK)

#---------------------------------------------------------------------------------
# no real need to edit anything past this point unless you need to add additional
# rules for different file extensions
#---------------------------------------------------------------------------------
ifneq ($(notdir $(BUILD)),$(notdir $(CURDIR)))
#---------------------------------------------------------------------------------

export VPATH	:=	$(foreach dir,$(SOURCES),$(CURDIR)/$(dir))

export DEPSDIR	:=	$(CURDIR)/$(BUILD)

#---------------------------------------------------------------------------------
# automatically build a list of object files for our project
#---------------------------------------------------------------------------------
CFILES			:=	$(foreach dir,$(SOURCES),$(notdir $(wildcard $(dir)/*.c)))
CPPFILES		:=	$(foreach dir,$(SOURCES),$(notdir $(wildcard $(dir)/*.cpp)))
ifneq ($(strip $(POLYPHASE_PIC)),)
BULLET_OFILES	:=	$(wildcard $(BULLET_DIR)/Intermediate/Linux-pic/*.o)
else
BULLET_OFILES	:=	$(wildcard $(BULLET_DIR)/Intermediate/Linux/*.o)
endif

#---------------------------------------------------------------------------------
# use CXX for linking C++ projects, CC for standard C
#---------------------------------------------------------------------------------
ifeq ($(strip $(CPPFILES)),)
	export LD	:=	$(CC)
else
	export LD	:=	$(CXX)
endif

export OFILES_SOURCES := $(CPPFILES:.cpp=.o) $(CFILES:.c=.o)
export OFILES := $(OFILES_SOURCES)
export OFILES_EXTRA := $(BULLET_OFILES)

#---------------------------------------------------------------------------------
# build a list of include paths
#---------------------------------------------------------------------------------
export INCLUDE	:=	$(foreach dir,$(INCLUDES),-I$(CURDIR)/$(dir)) \
					$(foreach dir,$(LIBDIRS),-I$(dir)/include) \
					-I$(CURDIR)/$(BUILD)

#---------------------------------------------------------------------------------
# build a list of library paths
#---------------------------------------------------------------------------------
export LIBPATHS	:=	$(foreach dir,$(LIBDIRS),-L$(dir)/lib)

ifneq ($(strip $(SHARED_BUILD)),)
export OUTPUT	:=	$(OUTPUT_DIR)/lib$(TARGET).so
else
export OUTPUT	:=	$(OUTPUT_DIR)/lib$(TARGET).a
endif
.PHONY: $(BUILD) clean shared

#---------------------------------------------------------------------------------
all: $(BUILD)

# W1: convenience entrypoints — `make -f Makefile_Linux shared` triggers a
# game-only build with -fPIC and links libPolyphaseGame.so;
# `make -f Makefile_Linux editor-shared` does the same but with EDITOR=1 and
# produces libPolyphaseEditor.so. Both re-invoke this very Makefile with the
# matching variable so the rules above retarget.
shared:
	@$(MAKE) --no-print-directory -f $(CURDIR)/Makefile_Linux POLYPHASE_SHARED=1

editor-shared:
	@$(MAKE) --no-print-directory -f $(CURDIR)/Makefile_Linux POLYPHASE_EDITOR_SHARED=1

OutputDir:
	[ -d $(OUTPUT_DIR) ] || mkdir -p $(OUTPUT_DIR)

MakeBullet:
	@$(MAKE) --no-print-directory -C $(BULLET_DIR) -f $(BULLET_DIR)/Makefile_Linux

MakeAssimp:
	@$(MAKE) --no-print-directory -C $(ASSIMP_DIR) -f $(ASSIMP_DIR)/Makefile_Linux

$(BUILD): MakeBullet MakeAssimp OutputDir
	@[ -d $@ ] || mkdir -p $@
	@$(MAKE) --no-print-directory -C $(BUILD) -f $(CURDIR)/Makefile_Linux

#---------------------------------------------------------------------------------
clean:
	@echo clean ...
	@rm -fr $(BUILD) $(OUTPUT_DIR)

#---------------------------------------------------------------------------------
else

#---------------------------------------------------------------------------------
# main targets
#---------------------------------------------------------------------------------
$(OUTPUT): $(OFILES) $(OFILES_EXTRA)

$(OFILES_EXTRA):

$(OFILES_SOURCES) :

-include $(DEPSDIR)/*.d

#---------------------------------------------------------------------------------
endif
#---------------------------------------------------------------------------------
