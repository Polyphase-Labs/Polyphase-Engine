#---------------------------------------------------------------------------------
# Clear the implicit built in rules
#---------------------------------------------------------------------------------
.SUFFIXES:
.SECONDARY:
#---------------------------------------------------------------------------------
export AS	:=	$(PREFIX)as
export CC	:=	$(PREFIX)gcc
export CXX	:=	$(PREFIX)g++
export AR	:=	$(PREFIX)gcc-ar
export OBJCOPY	:=	$(PREFIX)objcopy
export STRIP	:=	$(PREFIX)strip
export NM	:=	$(PREFIX)gcc-nm
export RANLIB	:=	$(PREFIX)gcc-ranlib

ifeq ($(V),1)
    SILENTMSG := @true
    SILENTCMD :=
else
    SILENTMSG := @echo
    SILENTCMD := @
endif

#---------------------------------------------------------------------------------
%.a:
#---------------------------------------------------------------------------------
	$(SILENTMSG) $(notdir $@)
	$(SILENTCMD)rm -f $@
	$(SILENTCMD)$(AR) -rc $@ $^

#---------------------------------------------------------------------------------
%.elf:
	$(SILENTMSG) linking ... $(notdir $@)
	$(SILENTCMD)$(LD)  $^ $(LDFLAGS) $(LIBPATHS) $(LIBS) -o $@

#---------------------------------------------------------------------------------
%.o: %.cpp
	$(SILENTMSG) $(notdir $<)
	$(SILENTCMD)$(CXX) -MMD -MP -MF $(DEPSDIR)/$*.d $(CXXFLAGS) -c $< -o $@ $(ERROR_FILTER)

#---------------------------------------------------------------------------------
%.o: %.c
	$(SILENTMSG) $(notdir $<)
	$(SILENTCMD)$(CC) -MMD -MP -MF $(DEPSDIR)/$*.d $(CFLAGS) -c $< -o $@ $(ERROR_FILTER)

#---------------------------------------------------------------------------------
# TARGET is the name of the output
# BUILD is the directory where object files & intermediate files will be placed
# SOURCES is a list of directories containing source code
# INCLUDES is a list of directories containing extra header files
#---------------------------------------------------------------------------------
TARGET		:=	Polyphase
BUILD		:=	Intermediate/Linux/Editor
SOURCES		:=	Source \
				Generated
INCLUDES	:=	Source ../Engine/Source  ../Engine/Source/Editor ../Engine/Source/Engine ../External ../External/Bullet $(VULKAN_SDK)/include \
				../External/Assimp ../External/IrrXML ../External/Zlib
OUTPUT_DIR	:=	$(CURDIR)/Build/Linux

#---------------------------------------------------------------------------------
# options for code generation
#---------------------------------------------------------------------------------

CFLAGS	= -g -O2 -Wall $(MACHDEP) -DEDITOR=1 -DPLATFORM_LINUX=1 -DAPI_VULKAN=1 $(INCLUDE)

# W1: shared-engine editor build (libPolyphaseEditor.so). Run
# `make -f Makefile_Linux_Editor POLYPHASE_SHARED=1`. POLYPHASE_DLL_CONSUMER=1
# turns on Standalone/Source/Main.cpp's exe-side entry-point + hook auto-register.
ifneq ($(strip $(POLYPHASE_SHARED)),)
CFLAGS		+=	-DPOLYPHASE_DLL_CONSUMER=1
BUILD		:=	Intermediate/Linux/EditorShared
LINK_ENGINE	:=	-lPolyphaseEditor
ENGINE_TARGET	:=	editor-shared
ENGINE_LIB_NAME	:=	libPolyphaseEditor.so
else
LINK_ENGINE	:=	-lEngineEditor
ENGINE_TARGET	:=
ENGINE_LIB_NAME	:=	libEngineEditor.a
endif

CXXFLAGS	=	$(CFLAGS)

LDFLAGS	=	-g $(MACHDEP) -Wl,-Map,$(notdir $@).map -rdynamic -Wl,-rpath,'$$ORIGIN'

#---------------------------------------------------------------------------------
# any extra libraries we wish to link with the project
#---------------------------------------------------------------------------------
LIBS	:=	$(LINK_ENGINE) -lspirv-cross-core -lshaderc_combined -lvulkan -lxcb -lasound -lpulse -lAssimp -lBullet -lgit2 -lssl -lcrypto -lpthread -lm

#---------------------------------------------------------------------------------
# list of directories containing libraries, this must be the top level containing
# include and lib
#---------------------------------------------------------------------------------
LIBDIRS	:= $(VULKAN_SDK) ../External/Assimp

#---------------------------------------------------------------------------------
# no real need to edit anything past this point unless you need to add additional
# rules for different file extensions
#---------------------------------------------------------------------------------
ifneq ($(notdir $(BUILD)),$(notdir $(CURDIR)))
#---------------------------------------------------------------------------------

export VPATH	:=	$(foreach dir,$(SOURCES),$(CURDIR)/$(dir))

export DEPSDIR	:=	$(CURDIR)/$(BUILD)

#---------------------------------------------------------------------------------
# automatically build a list of object files for our project
#---------------------------------------------------------------------------------
CFILES			:=	$(foreach dir,$(SOURCES),$(notdir $(wildcard $(dir)/*.c)))
CPPFILES		:=	$(foreach dir,$(SOURCES),$(notdir $(wildcard $(dir)/*.cpp)))

#---------------------------------------------------------------------------------
# use CXX for linking C++ projects, CC for standard C
#---------------------------------------------------------------------------------
ifeq ($(strip $(CPPFILES)),)
	export LD	:=	$(CC)
else
	export LD	:=	$(CXX)
endif

export OFILES_SOURCES := $(CPPFILES:.cpp=.o) $(CFILES:.c=.o)
export OFILES := $(OFILES_SOURCES)

#---------------------------------------------------------------------------------
# build a list of include paths
#---------------------------------------------------------------------------------
export INCLUDE	:=	$(foreach dir,$(INCLUDES),-I$(CURDIR)/$(dir)) \
					$(foreach dir,$(LIBDIRS),-I$(dir)/include) \
					-I$(CURDIR)/$(BUILD)

#---------------------------------------------------------------------------------
# build a list of library paths
#---------------------------------------------------------------------------------
export LIBPATHS	:=	$(foreach dir,$(LIBDIRS),-L$(dir)/lib) \
					-L$(CURDIR)/../External/Assimp/Build/Linux \
					-L$(CURDIR)/../External/Bullet/Build/Linux \
					-L$(CURDIR)/../Engine/Build/Linux \
					-L$(CURDIR)/../Engine/External/libgit2/build

export OUTPUT	:=	$(OUTPUT_DIR)/$(TARGET)Editor.elf
export ENGINE_LIB := $(CURDIR)/../Engine/Build/Linux/$(ENGINE_LIB_NAME)
# Only set POLYPHASE_EDITOR for the static-lib path; the shared path passes
# POLYPHASE_EDITOR_SHARED into MakeEngine which already implies EDITOR=1.
ifeq ($(strip $(POLYPHASE_SHARED)),)
export POLYPHASE_EDITOR	:= 1
endif
.PHONY: $(BUILD) clean

#---------------------------------------------------------------------------------
all: $(BUILD)

OutputDirs:
	[ -d $(OUTPUT_DIR) ] || mkdir -p $(OUTPUT_DIR)
	[ -d $(BUILD) ] || mkdir -p $(BUILD)

MakeEngine:
	$(MAKE) --no-print-directory -C $(CURDIR)/../Engine -f $(CURDIR)/../Engine/Makefile_Linux $(ENGINE_TARGET)

$(BUILD): OutputDirs MakeEngine
	[ -d $@ ] || mkdir -p $@
	$(MAKE) --no-print-directory -C $(BUILD) -f $(CURDIR)/$(firstword $(MAKEFILE_LIST))
ifneq ($(strip $(POLYPHASE_SHARED)),)
	cp $(ENGINE_LIB) $(OUTPUT_DIR)/$(ENGINE_LIB_NAME)
endif
	@# Mirror the Windows post-build copy: stash the latest editor binary at
	@# the repo root so callers (Tools/CI/run_local_verify.sh, dev shortcuts)
	@# always have a stable path to the freshest build. Suppress errors so a
	@# broken build doesn't mask the real failure with a copy error.
	@cp -f "$(OUTPUT_DIR)/$(TARGET)Editor.elf" "$(CURDIR)/.." 2>/dev/null || true

#---------------------------------------------------------------------------------
clean:
	@echo clean ...
	@rm -fr $(BUILD) $(OUTPUT_DIR)
	@export EDITOR=1
	@$(MAKE) clean --no-print-directory -C $(CURDIR)/../Engine -f $(CURDIR)/../Engine/Makefile_Linux

#---------------------------------------------------------------------------------
else

#---------------------------------------------------------------------------------
# main targets
#---------------------------------------------------------------------------------
$(OUTPUT): $(OFILES) $(ENGINE_LIB)

$(ENGINE_LIB): 

$(OFILES_SOURCES) : 

-include $(DEPSDIR)/*.d

#---------------------------------------------------------------------------------
endif
#---------------------------------------------------------------------------------
